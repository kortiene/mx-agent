# Copy to dev/matrix/.env (gitignored) and adjust as needed.
# scripts/matrix_dev.sh auto-creates dev/matrix/.env from this file on first use,
# generating a random registration token.

# Registration token for the LOCAL dev homeserver. This is not a real secret —
# the homeserver is throwaway and bound to 127.0.0.1 only — but it still must
# not be committed, so the real value lives in dev/matrix/.env.
MATRIX_REGISTRATION_TOKEN=dev-local-token

# Host port the homeserver is published on (loopback only).
MATRIX_PORT=8008
